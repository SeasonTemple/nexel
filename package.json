{
  "name": "nexel",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "description": "Kernel library for managing agent skills, agents, and rules across Claude Code, Codex, and OpenCode — product-agnostic installer driven by a per-product ProductConfig.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeasonTemple/nexel.git"
  },
  "homepage": "https://github.com/SeasonTemple/nexel",
  "bugs": {
    "url": "https://github.com/SeasonTemple/nexel/issues"
  },
  "keywords": [
    "skills",
    "agents",
    "installer",
    "skill-management",
    "claude-code",
    "codex",
    "opencode",
    "kernel-library",
    "nexel"
  ],
  "main": "./scripts/installer/index.mjs",
  "exports": {
    ".": "./scripts/installer/index.mjs",
    "./adapters/claude": "./scripts/installer/adapters/claude.mjs",
    "./adapters/claude-plugin": "./scripts/installer/adapters/claude-plugin.mjs",
    "./adapters/codex": "./scripts/installer/adapters/codex.mjs",
    "./adapters/codex-plugin": "./scripts/installer/adapters/codex-plugin.mjs",
    "./adapters/opencode": "./scripts/installer/adapters/opencode.mjs",
    "./adapters/opencode-plugin": "./scripts/installer/adapters/opencode-plugin.mjs",
    "./lint-skills": "./scripts/lint-skills.mjs",
    "./examples/sample-product/opencode-plugin": "./examples/sample-product/.opencode/plugins/sample-product.js"
  },
  "files": [
    "scripts/installer/**/*.mjs",
    "scripts/install-skills.mjs",
    "scripts/render-install-demo-gif.mjs",
    "scripts/lint-skills.mjs",
    "scripts/install-husky.mjs",
    "scripts/package-smoke.mjs",
    "scripts/release-prepare.mjs",
    "examples/sample-product/**",
    "assets/**",
    "README.md",
    "LICENSE",
    "scripts/build-dist.mjs",
    "scripts/release-preflight.mjs",
    "scripts/release-note-policy.mjs",
    "scripts/verify-release-tag.mjs",
    "scripts/verify-baseline.mjs",
    "scripts/lint-commit-msg.mjs",
    "docs/release-notes/**"
  ],
  "scripts": {
    "demo:install": "node scripts/install-skills.mjs",
    "demo:gif": "node scripts/render-install-demo-gif.mjs",
    "lint:skills": "node scripts/lint-skills.mjs --dir=examples/sample-product/skills --id-prefix=sample",
    "lint:manifest": "node scripts/installer/core/manifest/validator.mjs --manifest=examples/sample-product/sample.install.json",
    "lint:drift": "node scripts/installer/core/manifest/drift.mjs --manifest=examples/sample-product/sample.install.json",
    "lint:commit-msg": "node scripts/lint-commit-msg.mjs",
    "lint:release-sync": "node scripts/lint-release-sync.mjs",
    "fix:drift": "node scripts/installer/core/manifest/drift.mjs --manifest=examples/sample-product/sample.install.json --fix",
    "test:lint": "node --test scripts/lint-skills.test.mjs",
    "test:commit-msg": "node --test scripts/lint-commit-msg.test.mjs",
    "test:release-note-policy": "node --test scripts/release-note-policy.test.mjs",
    "test:release-sync": "node --test scripts/lint-release-sync.test.mjs",
    "test:plan": "node --test scripts/installer/core/plan.test.mjs",
    "test:errors": "node --test scripts/installer/core/errors.test.mjs",
    "test:asset-types": "node --test scripts/installer/core/asset-types.test.mjs",
    "test:which": "node --test scripts/installer/core/which.test.mjs",
    "test:validator": "node --test scripts/installer/core/manifest/validator.test.mjs",
    "test:drift": "node --test scripts/installer/core/manifest/drift.test.mjs",
    "test:stage-asset": "node --test scripts/installer/core/stage-asset.test.mjs",
    "test:repair-rehash": "node --test scripts/installer/cli/commands/repair-rehash.test.mjs",
    "test:loader": "node --test scripts/installer/core/manifest/loader.test.mjs",
    "test:product-config": "node --test scripts/installer/core/product-config.test.mjs",
    "test:argv": "node --test scripts/installer/cli/argv.test.mjs",
    "test:dispatch": "node --test scripts/installer/cli/dispatch.test.mjs",
    "test:commands": "node --test scripts/installer/cli/commands/index.test.mjs",
    "test:prompts": "node --test scripts/installer/cli/prompts.test.mjs",
    "test:strings": "node --test scripts/installer/cli/strings.test.mjs",
    "test:help": "node --test scripts/installer/cli/help.test.mjs",
    "test:error-format": "node --test scripts/installer/cli/error-format.test.mjs",
    "test:spi": "node --test scripts/installer/adapters/spi.test.mjs",
    "test:opencode": "node --test scripts/installer/adapters/opencode.test.mjs",
    "test:opencode-plugin": "node --test scripts/installer/adapters/opencode-plugin.test.mjs",
    "test:claude-plugin": "node --test scripts/installer/adapters/claude-plugin.test.mjs",
    "test:codex-plugin": "node --test scripts/installer/adapters/codex-plugin.test.mjs",
    "test:skill-metadata": "node --test scripts/installer/core/skill-metadata.test.mjs",
    "test:ambient-fence": "node --test scripts/installer/core/ambient-fence.test.mjs",
    "test:architecture": "node --test scripts/installer/architecture.test.mjs",
    "test:sample-bin": "node --test examples/sample-product/sample-bin.test.mjs",
    "test:install-demo": "node --test scripts/install-skills.test.mjs",
    "test:sample-plugin-layout": "node --test examples/sample-product/sample-plugin-layout.test.mjs",
    "test:sample-marketplace-contract": "node --test examples/sample-product/sample-marketplace-contract.test.mjs",
    "test:marketplace-lockstep": "node --test scripts/installer/core/marketplace-lockstep.test.mjs",
    "test:scaffold-plugin": "node --test scripts/installer/cli/commands/scaffold-plugin.test.mjs",
    "test:activate": "node --test scripts/installer/cli/commands/activate.test.mjs",
    "test": "node --test scripts/lint-skills.test.mjs scripts/lint-commit-msg.test.mjs scripts/lint-release-sync.test.mjs scripts/release-note-policy.test.mjs scripts/release-preflight.test.mjs scripts/verify-release-tag.test.mjs scripts/verify-baseline.test.mjs scripts/package-smoke.test.mjs scripts/release-prepare.test.mjs scripts/install-skills.test.mjs scripts/installer/core/manifest/loader.test.mjs scripts/installer/core/product-config.test.mjs scripts/installer/core/manifest/validator.test.mjs scripts/installer/core/manifest/drift.test.mjs scripts/installer/core/errors.test.mjs scripts/installer/core/asset-types.test.mjs scripts/installer/core/which.test.mjs scripts/installer/core/plan.test.mjs scripts/installer/core/stage-asset.test.mjs scripts/installer/cli/commands/repair-rehash.test.mjs scripts/installer/cli/commands/index.test.mjs scripts/installer/cli/commands/scaffold-plugin.test.mjs scripts/installer/cli/commands/activate.test.mjs scripts/installer/cli/argv.test.mjs scripts/installer/cli/dispatch.test.mjs scripts/installer/cli/help.test.mjs scripts/installer/cli/strings.test.mjs scripts/installer/cli/locale-isolation.test.mjs scripts/installer/cli/prompts.test.mjs scripts/installer/cli/error-format.test.mjs scripts/installer/adapters/spi.test.mjs scripts/installer/adapters/opencode.test.mjs scripts/installer/adapters/opencode-plugin.test.mjs scripts/installer/adapters/claude-plugin.test.mjs scripts/installer/adapters/codex-plugin.test.mjs scripts/installer/core/skill-metadata.test.mjs scripts/installer/core/ambient-fence.test.mjs scripts/installer/architecture.test.mjs scripts/installer/conformance.test.mjs examples/sample-product/sample-bin.test.mjs examples/sample-product/sample-opencode-plugin.test.mjs examples/sample-product/sample-plugin-layout.test.mjs examples/sample-product/sample-marketplace-contract.test.mjs scripts/installer/core/marketplace-lockstep.test.mjs",
    "setup:hooks": "husky",
    "prepare": "node scripts/install-husky.mjs",
    "release:patch": "npm version patch --no-git-tag-version",
    "release:minor": "npm version minor --no-git-tag-version",
    "release:major": "npm version major --no-git-tag-version",
    "release:prepare": "node scripts/release-prepare.mjs",
    "test:locale-isolation": "node --test scripts/installer/cli/locale-isolation.test.mjs",
    "test:baseline": "node --test scripts/verify-baseline.test.mjs",
    "test:release-preflight": "node --test scripts/release-preflight.test.mjs",
    "test:release-tag": "node --test scripts/verify-release-tag.test.mjs",
    "test:package-smoke": "node --test scripts/package-smoke.test.mjs",
    "test:release-prepare": "node --test scripts/release-prepare.test.mjs",
    "test:conformance": "node --test scripts/installer/conformance.test.mjs",
    "verify:baseline": "node scripts/verify-baseline.mjs",
    "package:smoke": "node scripts/package-smoke.mjs",
    "dist": "node scripts/build-dist.mjs",
    "release:preflight": "node scripts/release-preflight.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "yaml": "^2.6.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "figlet": "^1.11.0",
    "proper-lockfile": "^4.1.2",
    "write-file-atomic": "^8.0.0"
  },
  "engines": {
    "node": ">=22.22.2"
  }
}
