#!/usr/bin/env sh
# nexel repo pre-push: gate tag pushes on a per-tag review marker bound
# to the tag's referenced commit SHA.
#
# Harness hardening: scrub git env vars husky exports (see pre-commit
# header for full rationale). Without this, `git rev-parse <sha>^{commit}`
# below would honor GIT_DIR over the inherited shell context.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_OBJECT_DIRECTORY GIT_COMMON_DIR
#
# When a `git push` includes any `refs/tags/v*` ref, this hook checks for
# `.nexel/release-blessed-<tag>` (regular file, not a symlink) and verifies
# its embedded `commit=<sha>` line matches the local_sha being pushed for
# that tag. The marker is created by `npm run release:bless -- vX.Y.Z`
# after a green `ce-code-review` pass.
#
# Rationale: three consecutive releases (v0.7.0 / v0.8.0 / v0.8.1) shipped
# without prior review and each required a round-1 fixup commit, including
# two live-verified exploits. Memory + CLAUDE.md + release-workflow.md
# proved insufficient. v0.8.3 adds this mechanical gate; v0.8.3 round-2
# review showed the file-existence-only check was a one-keystroke bypass,
# so this revision binds the marker to the tag's commit SHA and rejects
# symlinks and tag deletions correctly.
#
# Non-tag pushes (e.g., `git push origin main`) pass through unchanged.
# Tag DELETIONS (`git push origin :v0.8.3`) pass through — there is no
# code to review on a delete.
# Stdin format per `git push` hook contract:
#   <local ref> <local sha> <remote ref> <remote sha>
# per line.
#
# Documented bypasses (emergency only, audit if used in normal flow):
#   git push --no-verify origin v0.8.3
#   HUSKY=0 git push origin v0.8.3
#   git -c core.hooksPath=/dev/null push origin v0.8.3
#
# ADR-0018 CI bless path: this hook is the MAINTAINER-MACHINE transport.
# A fresh CI runner has no `.husky/` installed (git does not invoke hooks
# during workflow steps), and the `.nexel/release-blessed-<tag>` marker
# is gitignored, so neither can reach CI via `actions/checkout`. The
# server-side enforcement of the same review-gate invariant lives in
# `.github/workflows/release.yml`'s `review-gate` job, which re-runs the
# deterministic review checks and sets `NEXEL_CI_BLESSED=true` on the
# `release` job's env so that `scripts/verify-release-tag.mjs` accepts
# the tag push. The local hook and the CI job are two transports for the
# same ADR-0013 invariant.

set -e

ZERO_SHA="0000000000000000000000000000000000000000"
FAILURES=""

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/tags/v*)
      # Tag deletion: local_sha is all zeros. Nothing to review on a delete.
      if [ "$local_sha" = "$ZERO_SHA" ]; then
        continue
      fi

      tag="${remote_ref#refs/tags/}"
      marker=".nexel/release-blessed-${tag}"

      # Reject symlinks — a symlink-to-regular-file would pass `-f` and let
      # an empty/spoofed marker slip the gate.
      if [ -L "$marker" ]; then
        FAILURES="${FAILURES}\n  ${tag}: marker is a symlink — rejected. Remove ${marker} and re-run npm run release:bless -- ${tag}."
        continue
      fi

      if [ ! -f "$marker" ]; then
        FAILURES="${FAILURES}\n  ${tag}: no bless marker. Run npm run release:bless -- ${tag} after ce-code-review."
        continue
      fi

      # Extract committed SHA from the marker. The expected line shape is
      # `commit=<40-char hex>`. Anything else is treated as untrusted.
      marker_sha=$(grep -E '^commit=[0-9a-f]{40}$' "$marker" | head -1 | cut -d= -f2 || true)
      if [ -z "$marker_sha" ]; then
        FAILURES="${FAILURES}\n  ${tag}: bless marker missing or malformed commit=<sha> line. Re-run npm run release:bless -- ${tag}."
        continue
      fi

      # Peel local_sha to its underlying commit. `git push` sends the tag
      # OBJECT SHA for annotated tags (and the commit SHA for lightweight
      # tags); the bless marker captures the commit. Peeling unifies both
      # cases so an annotated v0.8.3 tag pointing at commit C is recognized
      # the same as a lightweight v0.8.3 tag pointing directly at C.
      local_commit=$(git rev-parse --verify "${local_sha}^{commit}" 2>/dev/null || echo "$local_sha")

      if [ "$marker_sha" != "$local_commit" ]; then
        FAILURES="${FAILURES}\n  ${tag}: bless marker bound to ${marker_sha} but push refers to ${local_commit} (object ${local_sha}). The tag was amended or rewritten since bless. Re-run npm run release:bless -- ${tag}."
        continue
      fi
      ;;
  esac
done

if [ -n "$FAILURES" ]; then
  printf 'pre-push: refusing to push tag(s):%b\n' "$FAILURES" >&2
  echo "" >&2
  echo "Pre-tag code review is mandatory (CLAUDE.md 'Mandatory release-time review gate'," >&2
  echo "docs/release-workflow.md Normal path step 4)." >&2
  echo "" >&2
  echo "Emergency bypass (use only when reviewer chain is unavailable; audit if used):" >&2
  echo "  git push --no-verify origin <tag>" >&2
  exit 1
fi

exit 0
