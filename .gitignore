# Skill development artifacts — eval workspaces are throwaway test output
skills/*-workspace/

# Packaged skill bundles — generated artifacts (zip of the source dir)
skills/*/*.skill

# Node
node_modules/

# Vercel Labs skills CLI legacy artifacts (from prior wrapper smoke tests).
# Kept ignored because old clones may still have them; remove this block
# once everyone has cleaned them up.
.agents/skills/
skills-lock.json

# NetOps managed installer state (only ever lives inside <target>/.netops-agent-skills/
# in user homes; this entry guards against accidental commits if someone
# runs the installer with --target=. from this repo working tree).
.netops-agent-skills/

# husky auto-generated dir (regenerated by `prepare: husky` on npm install)
.husky/_/

# compound-engineering scratch artifacts (per-session, not portable)
.context/
pnpm-lock.yaml

# Tarball dist artifacts (generated by npm run dist)
*.tgz
*.tgz.sha256

# Credential / secret files — never accept these into git.
# Names cover common conventions (env vars, ad-hoc PAT files, GitLab CI
# job tokens, ad-hoc release-helper payload dumps).
.env
.env.*
!.env.example
*.pat
*-token
*-token.txt
*-secret
*-secret.txt
.gitlab-credentials
.gitlab-token
# Release helper temp payloads (if a future script writes them in-repo).
*-payload.json
release-payload-*.json
